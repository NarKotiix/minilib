# Backend - Node.js/Express
NODE_ENV=development
PORT=5000

# Database - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=minilib
DB_USER=postgres
DB_PASSWORD=your_password_here

# Frontend - React
REACT_APP_API_URL=http://localhost:5000/api

# Docker - PostgreSQL (pour docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=minilib

# Optionnel - JWT pour l'authentification (si implémenté plus tard)
# JWT_SECRET=your_secret_key_here
# JWT_EXPIRES_IN=24h
